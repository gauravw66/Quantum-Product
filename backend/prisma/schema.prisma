generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  passwordHash    String
  createdAt       DateTime         @default(now())
  jobs            Job[]
  quantumAccounts QuantumAccount[]
}

model QuantumAccount {
  id          String   @id @default(uuid())
  userId      String
  provider    String
  token       String
  backendName String?
  instance    String?
  createdAt   DateTime @default(now())
  name        String?  @default("IBM Cloud Instance") @db.VarChar(255)
  user        User     @relation(fields: [userId], references: [id])
}

model Module {
  id                 String @id @default(uuid())
  name               String
  description        String
  qiskitCodeTemplate String
}

model Job {
  id        String   @id @default(uuid())
  userId    String
  jobName   String
  code      String
  backend   String
  status    String
  ibmJobId  String?
  result    Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
